# =============================================================================
# .gitignore — Proyecto Cloudflare con Gobernanza de Agentes
# =============================================================================

# -----------------------------------------------------------------------------
# Wrangler y Cloudflare
# -----------------------------------------------------------------------------
.wrangler/
.dev.vars
.dev.vars.example
!wrangler.toml
!wrangler.jsonc

# -----------------------------------------------------------------------------
# Variables de entorno y secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.example
*.env

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
*.min.js
*.min.css

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# IDE y editores
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Temporal y caché
# -----------------------------------------------------------------------------
temp/
tmp/
.cache/
.parcel-cache/

# -----------------------------------------------------------------------------
# Scripts de prueba (opcional)
# -----------------------------------------------------------------------------
# scripts/cloudflare-connection-test.sh

# -----------------------------------------------------------------------------
# Documentos temporales de análisis
# -----------------------------------------------------------------------------
temp/Analisis_*.md
